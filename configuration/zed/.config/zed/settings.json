// Zed settings
// https://zed.dev/docs/configuring-zed
{
  "cli_default_open_behavior": "new_window",
  "hover_popover_delay": 200,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light Hard",
    "dark": "Gruvbox Dark Hard"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme"
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "show_edit_predictions": true,
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "default_profile": "write",
    "use_modifier_to_send": true,
    "enable_feedback": false,
    "play_sound_when_agent_done": "always",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-thinking-latest"
    },
    "model_parameters": []
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "format_on_save": "off",
  "terminal": {
    "font_family": "MesloLGL Nerd Font Mono",
    "line_height": "standard"
  },
  "buffer_font_size": 15,
  "tab_size": 2,
  "ui_font_size": 15,
  "wrap_guides": [80, 120],
  "languages": {
    "Ruby": {
      "language_servers": ["ruby-lsp", "rubocop"]
    }
  },
  "lsp": {
    "pony-lsp": {
      "settings": {
        "executable": "/Users/orienmadgwick/pony/bin/pony-lsp",
        "ponypath": ["/path1"],
        "defines": ["FOO", "BAT", "BAZ"]
      }
    },
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false
        }
      }
    }
  }
}
